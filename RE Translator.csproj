<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>RE_Translator</RootNamespace>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="textFiles\re4_1_en.txt" />
    <None Remove="textFiles\re4_1_tr.txt" />
    <None Remove="textFiles\re4_2_en.txt" />
    <None Remove="textFiles\re4_2_tr.txt" />
    <None Remove="textFiles\re4_3_en.txt" />
    <None Remove="textFiles\re4_3_tr.txt" />
    <None Remove="textFiles\re8_1_en.txt" />
    <None Remove="textFiles\re8_1_tr.txt" />
    <None Remove="textFiles\re_en.txt" />
    <None Remove="textFiles\re_tr.txt" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="textFiles\re_en.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="textFiles\re_tr.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>